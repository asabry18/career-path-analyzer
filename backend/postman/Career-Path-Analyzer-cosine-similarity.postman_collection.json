        },
        {
          "name": "pipeline preview — similarity + AHP + TOPSIS (threshold 0)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var b = pm.response.json();",
                  "pm.test('has ahp.weights', function () { pm.expect(b.ahp && b.ahp.weights).to.be.ok; });",
                  "if (b.ahp && b.ahp.weights) {",
                  "  var sum = 0;",
                  "  for (var k in b.ahp.weights) { sum += b.ahp.weights[k]; }",
                  "  pm.test('AHP weights sum to 1', function () { pm.expect(sum).to.be.within(0.999, 1.001); });",
                  "}",
                  "pm.test('has ranked_jobs array', function () { pm.expect(b.ranked_jobs).to.be.an('array'); });",
                  "if (b.ranked_jobs && b.ranked_jobs.length > 1) {",
                  "  pm.test('TOPSIS: rank 1 closeness ≥ last', function () {",
                  "    pm.expect(b.ranked_jobs[0].topsis_score).to.be.at.least(b.ranked_jobs[b.ranked_jobs.length - 1].topsis_score);",
                  "  });",
                  "}",
                  "if (b.ranked_jobs && b.ranked_jobs.length > 0) {",
                  "  pm.collectionVariables.set('pipeline_top_job_id', String(b.ranked_jobs[0].job_id));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"weights\": {\n    \"{{skill_id_1}}\": 0.6,\n    \"{{skill_id_2}}\": 0.9\n  },\n  \"pairwise\": [\n    { \"a\": \"skill_match\", \"b\": \"salary\", \"value\": 3 },\n    { \"a\": \"skill_match\", \"b\": \"demand\", \"value\": 5 },\n    { \"a\": \"skill_match\", \"b\": \"learning_effort\", \"value\": 7 },\n    { \"a\": \"salary\", \"b\": \"demand\", \"value\": 3 },\n    { \"a\": \"salary\", \"b\": \"learning_effort\", \"value\": 5 },\n    { \"a\": \"demand\", \"b\": \"learning_effort\", \"value\": 3 }\n  ],\n  \"threshold\": 0.0,\n  \"limit_jobs\": 35\n}"
            },
            "url": "{{base_url}}/api/test/pipeline-preview/"
          }
        },
