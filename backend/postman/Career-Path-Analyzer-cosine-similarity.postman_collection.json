                  "  pm.test('empty ranks explained', function () { pm.expect(b.detail).to.be.a('string'); });",
                  "}",
                  "if (b.ranked_jobs && b.ranked_jobs.length > 0) {",
                  "  pm.test('each row has TOPSIS score', function () {",
                  "    pm.expect(b.ranked_jobs[0].topsis_score).to.be.a('number');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
