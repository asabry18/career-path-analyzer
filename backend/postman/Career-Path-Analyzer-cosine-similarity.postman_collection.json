        {
          "name": "similarity preview — numeric weights",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', function () { pm.response.to.have.status(200); });",
                  "var b = pm.response.json();",
                  "pm.test('has jobs_preview', function () { pm.expect(b.jobs_preview).to.be.an('array'); });",
                  "pm.test('scenario_vocab_size', function () { pm.expect(b.scenario_vocab_size).to.be.above(0); });",
                  "if (b.jobs_preview && b.jobs_preview.length >= 2) {",
                  "  var n0 = b.jobs_preview[0].norm_user_vector;",
                  "  pm.test('shared user norm across jobs', function () { pm.expect(b.jobs_preview[1].norm_user_vector).to.eql(n0); });",
                  "}"
