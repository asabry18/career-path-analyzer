    {
      "name": "Analyze API (POST /api/analyze/)",
      "item": [
        {
          "name": "Test 1 — PDF scenario: demand-priority frontend user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "",
                  "var b = pm.response.json();",
                  "",
                  "// ── AHP weights ──",
                  "pm.test('has ahp object', function () { pm.expect(b.ahp).to.be.an('object'); });",
                  "pm.test('AHP consistency_ok is true', function () { pm.expect(b.ahp.consistency_ok).to.be.true; });",
                  "pm.test('AHP CR < 0.1', function () { pm.expect(b.ahp.consistency_ratio).to.be.below(0.1); });",
                  "",
                  "if (b.ahp && b.ahp.weights) {",
                  "  var w = b.ahp.weights;",
                  "  var sum = 0; for (var k in w) { sum += w[k]; }",
                  "  pm.test('AHP weights sum ≈ 1', function () { pm.expect(sum).to.be.within(0.999, 1.001); });",
                  "  pm.test('demand has highest weight (~0.577)', function () { pm.expect(w.demand).to.be.above(0.50); });",
                  "  pm.test('learning_effort > skill_match', function () { pm.expect(w.learning_effort).to.be.above(w.skill_match); });",
                  "  pm.test('skill_match > salary', function () { pm.expect(w.skill_match).to.be.above(w.salary); });",
                  "  pm.test('salary is smallest weight', function () { pm.expect(w.salary).to.be.below(0.10); });",
                  "}",
                  "",
                  "// ── Ranked jobs ──",
                  "pm.test('has ranked_jobs array', function () { pm.expect(b.ranked_jobs).to.be.an('array'); });",
                  "pm.test('at least 1 ranked job', function () { pm.expect(b.ranked_jobs.length).to.be.above(0); });",
                  "",
                  "if (b.ranked_jobs && b.ranked_jobs.length > 1) {",
                  "  pm.test('TOPSIS scores descending', function () {",
                  "    for (var i = 1; i < b.ranked_jobs.length; i++) {",
                  "      pm.expect(b.ranked_jobs[i-1].topsis_score).to.be.at.least(b.ranked_jobs[i].topsis_score);",
                  "    }",
                  "  });",
                  "}",
                  "",
                  "if (b.ranked_jobs && b.ranked_jobs.length > 0) {",
                  "  var top = b.ranked_jobs[0];",
                  "  pm.test('top job has required fields', function () {",
                  "    pm.expect(top.rank).to.eql(1);",
                  "    pm.expect(top.title).to.be.a('string');",
                  "    pm.expect(top.topsis_score).to.be.a('number');",
                  "    pm.expect(top.skill_match_score).to.be.a('number');",
                  "    pm.expect(top.avg_salary).to.be.a('number');",
                  "    pm.expect(top.demand_score).to.be.a('number');",
                  "    pm.expect(top.learning_effort).to.be.a('number');",
                  "    pm.expect(top.missing_skills).to.be.an('array');",
                  "    pm.expect(top.optional_frameworks).to.be.an('array');",
                  "    pm.expect(top.description).to.be.a('string');",
                  "  });",
                  "}",
                  "",
                  "// ── Learning plan ──",
                  "pm.test('has learning_plan', function () { pm.expect(b.learning_plan).to.be.an('object'); });",
                  "pm.test('learning_plan has selected_courses', function () { pm.expect(b.learning_plan.selected_courses).to.be.an('array'); });",
                  "pm.test('learning_plan solver_status', function () { pm.expect(b.learning_plan.solver_status).to.be.a('string'); });",
                  "",
                  "// ── Meta ──",
                  "pm.test('has meta object', function () { pm.expect(b.meta).to.be.an('object'); });",
                  "pm.test('meta.jobs_evaluated > 0', function () { pm.expect(b.meta.jobs_evaluated).to.be.above(0); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"skills\": [\n    { \"name\": \"HTML\", \"level\": \"Average\" },\n    { \"name\": \"CSS\", \"level\": \"Average\" },\n    { \"name\": \"JavaScript\", \"level\": \"Advanced\" },\n    { \"name\": \"React\", \"level\": \"Advanced\" }\n  ],\n  \"priorities\": [\"demand\", \"learn\", \"match\", \"salary\"],\n  \"threshold\": 0.4\n}"
            },
            "url": "{{base_url}}/api/analyze/"
