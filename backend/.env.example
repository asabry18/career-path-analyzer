# Copy to `.env` and adjust. Never commit `.env`.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Postgres (production / local Postgres). Omit to use SQLite in development.
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/career_path_analyzer

# Or discrete variables (used when DATABASE_URL is not set):
# DB_NAME=career_path_analyzer
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

# Comma-separated frontend origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production only (comma-separated hosts)
# ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com
